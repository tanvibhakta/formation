{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/block-sed-awk.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/tanvibhakta/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true,
    "example-skills@anthropic-agent-skills": true,
    "typescript-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "azath-workflows@azath": true,
    "posthog@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "azath": {
      "source": {
        "source": "git",
        "url": "git@github.com:Alt-AI-Inc/azath.git"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "voiceEnabled": false
}
