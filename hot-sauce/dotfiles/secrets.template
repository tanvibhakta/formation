# Secrets template - copy to ~/.secrets and fill in values
# This file is sourced by ~/.zshrc
# NEVER commit the real ~/.secrets file

export AWS_ACCESS_KEY_ID=
export AWS_SECRET_ACCESS_KEY=

export LINEAR_API_KEY=

export NEON_API_KEY=

export NPM_TOKEN=

# gh CLI auth (also prevents gh from writing tokens into hot-sauce/config/gh/hosts.yml)
export GH_TOKEN=
